# udev rules for RescueRobot2026 USB2CAN Adapters
#
# These rules create stable symlinks for the STM32-based USB2CAN adapters
# based on their unique hardware serial numbers.
#
# Installation:
#   1. sudo cp 99-usb2can.rules /etc/udev/rules.d/
#   2. sudo udevadm control --reload-rules
#   3. sudo udevadm trigger
#
# The devices will then be accessible as:
#   /dev/usb2can_a
#   /dev/usb2can_b

# Robot A Adapter (STM32 UID: 205E3990534B)
SUBSYSTEM=="tty", ATTRS{serial}=="209B3988534B", SYMLINK+="usb2can_a", MODE="0666"

# Robot B Adapter (STM32 UID: 209A3991534B)
SUBSYSTEM=="tty", ATTRS{serial}=="209A3991534B", SYMLINK+="usb2can_b", MODE="0666"
