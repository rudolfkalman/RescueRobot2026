# udev rules for RescueRobot2026 ESP32 servo controllers (robot_b)
#
# Installation:
#   1. sudo cp 99-esp-arm.rules /etc/udev/rules.d/
#   2. sudo udevadm control --reload-rules
#   3. sudo udevadm trigger
#
# Find identifiers with:
#   udevadm info -a -n /dev/ttyUSBx | grep -E 'serial|idVendor|idProduct'
# For CH340 (no unique serial), use USB port position instead:
#   udevadm info -a -n /dev/ttyUSBx | grep KERNELS | head -3

# esp_arm8: 8-axis arm (CP2102, unique serial)
SUBSYSTEM=="tty", ATTRS{serial}=="9abb01a1ca9bef11a8fdaf9061ce3355", SYMLINK+="esp_arm8", MODE="0666"

# esp_arm1: 1-axis gripper — fill in serial after connecting the board:
#   udevadm info -a -n /dev/ttyUSB0 | grep serial | head -1
SUBSYSTEM=="tty", ATTRS{serial}=="REPLACE_WITH_SERIAL", SYMLINK+="esp_arm1", MODE="0666"
# If CH340 (no unique serial), use USB port position:
# SUBSYSTEM=="tty", KERNELS=="REPLACE_WITH_PORT", SYMLINK+="esp_arm1", MODE="0666"
